{
  "name": "company-screener",
  "version": "1.0.0",
  "description": "PE company screening tool powered by Claude + web search",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"cyan,green\" \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
